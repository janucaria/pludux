{
  "version": 2,
  "series": {
    "bbands": {
      "method": "BB",
      "params": {
        "period": 20,
        "stddev": 2
      }
    },
    "bb_upper": {
      "method": "SELECT_OUTPUT",
      "params": {
        "output": "upper-band",
        "source": {
          "method": "SERIES_REFERENCE",
          "params": {
            "name": "bbands"
          }
        }
      }
    },
    "bb_lower": {
      "method": "SELECT_OUTPUT",
      "params": {
        "output": "lower-band",
        "source": {
          "method": "SERIES_REFERENCE",
          "params": {
            "name": "bbands"
          }
        }
      }
    }
  },
  "risk": {
    "method": "ATR",
    "atr": {
      "period": 14,
      "multiplier": 2
    },
    "percentage": 5,
    "value": 1000
  },
  "stopLoss": {
    "isTrailing": true
  },
  "takeProfit": {
    "riskMultiplier": 2
  },
  "shortPosition": {
    "entry": {
      "signal": {
        "method": "CROSSOVER",
        "params": {
          "value": "CLOSE",
          "baseline": {
            "method": "SERIES_REFERENCE",
            "params": {
              "name": "bb_lower"
            }
          }
        }
      }
    },
    "exit": {
      "signal": {
        "method": "CROSSUNDER",
        "params": {
          "value": "CLOSE",
          "baseline": {
            "method": "SERIES_REFERENCE",
            "params": {
              "name": "bb_upper"
            }
          }
        }
      }
    }
  }
}