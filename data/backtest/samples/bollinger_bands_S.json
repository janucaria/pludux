{
  "version": 2,
  "series": {
    "bbands": {
      "method": "BB",
      "params": {
        "period": 20,
        "stddev": 2
      }
    },
    "bb_upper": {
      "method": "SELECT_OUTPUT",
      "params": {
        "output": "upper-band",
        "source": {
          "method": "SERIES_NODE",
          "params": {
            "name": "bbands"
          }
        }
      }
    },
    "bb_lower": {
      "method": "SELECT_OUTPUT",
      "params": {
        "output": "lower-band",
        "source": {
          "method": "SERIES_NODE",
          "params": {
            "name": "bbands"
          }
        }
      }
    }
  },
  "stopLoss": {
    "trailing": true
  },
  "takeProfit": {
    "rMultiple": 2
  },
  "positions": {
    "short": {
      "entry": {
        "signal": {
          "method": "CROSSOVER",
          "params": {
            "value": "CLOSE",
            "baseline": {
              "method": "SERIES_VALUE",
              "params": {
                "name": "bb_lower"
              }
            }
          }
        }
      },
      "exit": {
        "signal": {
          "method": "CROSSUNDER",
          "params": {
            "value": "CLOSE",
            "baseline": {
              "method": "SERIES_VALUE",
              "params": {
                "name": "bb_upper"
              }
            }
          }
        }
      }
    }
  },
  "plots": [
    {
      "label": "BB",
      "overlay": true,
      "items": [
        {
          "method": "LINE",
          "params": {
            "source": {
              "method": "SERIES",
              "params": {
                "name": "bb_upper"
              }
            },
            "color": "aliceblue"
          }
        },
        {
          "method": "LINE",
          "params": {
            "source": {
              "method": "SERIES",
              "params": {
                "name": "bb_lower"
              }
            },
            "color": "lightslategray"
          }
        }
      ]
    }
  ]
}