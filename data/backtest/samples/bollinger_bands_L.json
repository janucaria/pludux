{
  "version": 2,
  "series": {
    "bb_upper": {
      "method": "SELECT_OUTPUT",
      "params": {
        "output": "upper-band",
        "source": {
          "method": "BB",
          "params": {
            "period": 20,
            "stddev": 2
          }
        }
      }
    },
    "bb_lower": {
      "method": "SELECT_OUTPUT",
      "params": {
        "output": "lower-band",
        "source": {
          "method": "SERIES_REFERENCE",
          "params": {
            "name": "bb_upper"
          }
        }
      }
    }
  },
  "stopLoss": {
    "trailing": false
  },
  "takeProfit": {
    "enabled": true,
    "rMultiple": 2
  },
  "longPosition": {
    "entry": {
      "signal": {
        "method": "CROSSOVER",
        "params": {
          "value": "CLOSE",
          "baseline": {
            "method": "SERIES_REFERENCE",
            "params": {
              "name": "bb_lower"
            }
          }
        }
      }
    },
    "exit": {
      "signal": {
        "method": "CROSSUNDER",
        "params": {
          "value": "CLOSE",
          "baseline": {
            "method": "SERIES_REFERENCE",
            "params": {
              "name": "bb_upper"
            }
          }
        }
      }
    }
  }
}