{
  "version": 2,
  "series": {
    "stoch_rsi": {
      "method": "STOCH_RSI",
      "params": {
        "kPeriod": 14,
        "kSmooth": 3,
        "dPeriod": 3,
        "rsiInput": "CLOSE",
        "rsiPeriod": 14
      }
    },
    "stoch_rsi_k": {
      "method": "SELECT_OUTPUT",
      "params": {
        "output": "k-percent",
        "source": {
          "method": "SERIES_REFERENCE",
          "params": {
            "name": "stoch_rsi"
          }
        }
      }
    },
    "stoch_rsi_d": {
      "method": "SELECT_OUTPUT",
      "params": {
        "output": "d-percent",
        "source": {
          "method": "SERIES_REFERENCE",
          "params": {
            "name": "stoch_rsi"
          }
        }
      }
    },
    "overbought": {
      "method": "VALUE",
      "params": {
        "value": 80
      }
    },
    "oversold": {
      "method": "VALUE",
      "params": {
        "value": 20
      }
    }
  },
  "risk": {
    "method": "ATR",
    "atr": {
      "period": 14,
      "multiplier": 2
    },
    "percentage": 5,
    "value": 1000
  },
  "stopLoss": true,
  "takeProfit": {
    "riskMultiplier": 3
  },
  "longPosition": {
    "entry": {
      "signal": {
        "method": "ALL_OF",
        "params": {
          "items": [
            {
              "method": "CROSSOVER",
              "params": {
                "value": {
                  "method": "SERIES_REFERENCE",
                  "params": {
                    "name": "stoch_rsi_k"
                  }
                },
                "baseline": {
                  "method": "SERIES_REFERENCE",
                  "params": {
                    "name": "stoch_rsi_d"
                  }
                }
              }
            },
            {
              "method": "LESS_THAN",
              "params": {
                "target": {
                  "method": "SERIES_REFERENCE",
                  "params": {
                    "name": "stoch_rsi_k"
                  }
                },
                "threshold": {
                  "method": "SERIES_REFERENCE",
                  "params": {
                    "name": "oversold"
                  }
                }
              }
            }
          ]
        }
      }
    },
    "exit": {
      "signal": {
        "method": "ALL_OF",
        "params": {
          "items": [
            {
              "method": "CROSSUNDER",
              "params": {
                "value": {
                  "method": "SERIES_REFERENCE",
                  "params": {
                    "name": "stoch_rsi_k"
                  }
                },
                "baseline": {
                  "method": "SERIES_REFERENCE",
                  "params": {
                    "name": "stoch_rsi_d"
                  }
                }
              }
            },
            {
              "method": "GREATER_THAN",
              "params": {
                "target": {
                  "method": "SERIES_REFERENCE",
                  "params": {
                    "name": "stoch_rsi_k"
                  }
                },
                "threshold": {
                  "method": "SERIES_REFERENCE",
                  "params": {
                    "name": "overbought"
                  }
                }
              }
            }
          ]
        }
      }
    }
  }
}