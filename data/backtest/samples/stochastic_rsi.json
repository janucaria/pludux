{
  "version": 2,
  "series": {
    "stoch_rsi": {
      "method": "STOCH_RSI",
      "params": {
        "kPeriod": 14,
        "kSmooth": 3,
        "dPeriod": 3,
        "rsiInput": "CLOSE",
        "rsiPeriod": 14
      }
    },
    "stoch_rsi_k": {
      "method": "SELECT_OUTPUT",
      "params": {
        "output": "k-percent",
        "source": {
          "method": "SERIES_NODE",
          "params": {
            "name": "stoch_rsi"
          }
        }
      }
    },
    "stoch_rsi_d": {
      "method": "SELECT_OUTPUT",
      "params": {
        "output": "d-percent",
        "source": {
          "method": "SERIES_NODE",
          "params": {
            "name": "stoch_rsi"
          }
        }
      }
    },
    "overbought": {
      "method": "VALUE",
      "params": {
        "value": 80
      }
    },
    "oversold": {
      "method": "VALUE",
      "params": {
        "value": 20
      }
    }
  },
  "stopLoss": true,
  "takeProfit": {
    "rMultiple": 3
  },
  "positions": {
    "long": {
      "entry": {
        "signal": {
          "method": "ALL_OF",
          "params": {
            "items": [
              {
                "method": "CROSSOVER",
                "params": {
                  "value": {
                    "method": "SERIES_VALUE",
                    "params": {
                      "name": "stoch_rsi_k"
                    }
                  },
                  "baseline": {
                    "method": "SERIES_VALUE",
                    "params": {
                      "name": "stoch_rsi_d"
                    }
                  }
                }
              },
              {
                "method": "LESS_THAN",
                "params": {
                  "target": {
                    "method": "SERIES_VALUE",
                    "params": {
                      "name": "stoch_rsi_k"
                    }
                  },
                  "threshold": {
                    "method": "SERIES_VALUE",
                    "params": {
                      "name": "oversold"
                    }
                  }
                }
              }
            ]
          }
        }
      },
      "exit": {
        "signal": {
          "method": "ALL_OF",
          "params": {
            "items": [
              {
                "method": "CROSSUNDER",
                "params": {
                  "value": {
                    "method": "SERIES_VALUE",
                    "params": {
                      "name": "stoch_rsi_k"
                    }
                  },
                  "baseline": {
                    "method": "SERIES_VALUE",
                    "params": {
                      "name": "stoch_rsi_d"
                    }
                  }
                }
              },
              {
                "method": "GREATER_THAN",
                "params": {
                  "target": {
                    "method": "SERIES_VALUE",
                    "params": {
                      "name": "stoch_rsi_k"
                    }
                  },
                  "threshold": {
                    "method": "SERIES_VALUE",
                    "params": {
                      "name": "overbought"
                    }
                  }
                }
              }
            ]
          }
        }
      }
    }
  },
  "plots": [
    {
      "label": "Stoch RSI",
      "overlay": false,
      "items": [
        {
          "method": "LINE",
          "params": {
            "source": {
              "method": "SERIES",
              "params": {
                "name": "stoch_rsi_k"
              }
            },
            "color": "yellow"
          }
        },
        {
          "method": "LINE",
          "params": {
            "source": {
              "method": "SERIES",
              "params": {
                "name": "stoch_rsi_d"
              }
            },
            "color": "cyan"
          }
        },
        {
          "method": "HLINE",
          "params": {
            "level": 80,
            "color": "#FFFFFF"
          }
        },
        {
          "method": "HLINE",
          "params": {
            "level": 20,
            "color": "#FFFFFF"
          }
        }
      ]
    }
  ]
}