{
  "version": 2,
  "series": {
    "kchannel": {
      "method": "KC",
      "params": {
        "maPeriod": 20,
        "maMethodType": "EMA",
        "bandMethodType": "ATR",
        "bandAtrPeriod": 10,
        "multiplier": 2
      }
    },
    "kc_upper": {
      "method": "SELECT_OUTPUT",
      "params": {
        "output": "upper-band",
        "source": {
          "method": "SERIES_REFERENCE",
          "params": {
            "name": "kchannel"
          }
        }
      }
    },
    "kc_lower": {
      "method": "SELECT_OUTPUT",
      "params": {
        "output": "lower-band",
        "source": {
          "method": "SERIES_REFERENCE",
          "params": {
            "name": "kchannel"
          }
        }
      }
    }
  },
  "stopLoss": true,
  "takeProfit": {
    "rMultiple": 5
  },
  "longPosition": {
    "entry": {
      "signal": {
        "method": "CROSSOVER",
        "params": {
          "value": "CLOSE",
          "baseline": {
            "method": "SERIES_REFERENCE",
            "params": {
              "name": "kc_lower"
            }
          }
        }
      }
    },
    "exit": {
      "signal": {
        "method": "CROSSUNDER",
        "params": {
          "value": "CLOSE",
          "baseline": {
            "method": "SERIES_REFERENCE",
            "params": {
              "name": "kc_upper"
            }
          }
        }
      }
    }
  }
}