{
  "version": 2,
  "series": {
    "kchannel": {
      "method": "KC",
      "params": {
        "maPeriod": 20,
        "maMethodType": "EMA",
        "bandMethodType": "ATR",
        "bandAtrPeriod": 10,
        "multiplier": 2
      }
    },
    "kc_upper": {
      "method": "SELECT_OUTPUT",
      "params": {
        "output": "upper-band",
        "source": {
          "method": "SERIES_NODE",
          "params": {
            "name": "kchannel"
          }
        }
      }
    },
    "kc_lower": {
      "method": "SELECT_OUTPUT",
      "params": {
        "output": "lower-band",
        "source": {
          "method": "SERIES_NODE",
          "params": {
            "name": "kchannel"
          }
        }
      }
    }
  },
  "stopLoss": true,
  "takeProfit": {
    "rMultiple": 5
  },
  "positions": {
    "long": {
      "entry": {
        "signal": {
          "method": "CROSSOVER",
          "params": {
            "value": "CLOSE",
            "baseline": {
              "method": "SERIES_VALUE",
              "params": {
                "name": "kc_lower"
              }
            }
          }
        }
      },
      "exit": {
        "signal": {
          "method": "CROSSUNDER",
          "params": {
            "value": "CLOSE",
            "baseline": {
              "method": "SERIES_VALUE",
              "params": {
                "name": "kc_upper"
              }
            }
          }
        }
      }
    }
  },
  "plots": [
    {
      "label": "KC",
      "overlay": true,
      "items": [
        {
          "method": "LINE",
          "params": {
            "source": {
              "method": "SERIES",
              "params": {
                "name": "kc_upper"
              }
            },
            "color": "aliceblue"
          }
        },
        {
          "method": "LINE",
          "params": {
            "source": {
              "method": "SERIES",
              "params": {
                "name": "kc_lower"
              }
            },
            "color": "lightslategray"
          }
        }
      ]
    }
  ]
}