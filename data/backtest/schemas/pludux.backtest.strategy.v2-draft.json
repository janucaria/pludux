    "hexColor": {
      "type": "string",
      "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$"
    },
    "rgbColor": {
      "type": "string",
      "pattern": "^rgb\\((\\s*([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\\s*,){2}\\s*([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\\s*\\)$"
    },
    "rgbaColor": {
      "type": "string",
      "pattern": "^rgba\\((\\s*([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\\s*,){3}\\s*(0|0?\\.\\d+|1(\\.0)?)\\s*\\)$"
    },
