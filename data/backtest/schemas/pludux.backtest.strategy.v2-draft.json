        },
        {
          "$ref": "#/$defs/hexColor"
        },
        {
          "$ref": "#/$defs/rgbColor"
        },
        {
          "$ref": "#/$defs/rgbaColor"
        }
      ]
    },
    "plotSource": {
      "oneOf": [
        {
          "$ref": "#/$defs/seriesPlotSource"
        },
        {
          "$ref": "#/$defs/constantPlotSource"
        }
      ]
    },
    "seriesPlotSource": {
      "allOf": [
        {
          "$ref": "#/$defs/baseMethod"
        },
        {
          "properties": {
            "method": {
              "const": "SERIES"
            },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_]*$"
                }
              },
              "required": [
                "name"
              ]
            }
          },
          "required": [
            "params"
          ]
        }
      ]
    },
    "constantPlotSource": {
      "allOf": [
        {
          "$ref": "#/$defs/baseMethod"
        },
        {
          "properties": {
            "method": {
              "const": "CONSTANT"
            },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "value": {
                  "type": "number"
                }
              },
              "required": [
                "value"
              ]
            }
          },
          "required": [
            "params"
          ]
        }
      ]
    },
    "linePlot": {
      "allOf": [
